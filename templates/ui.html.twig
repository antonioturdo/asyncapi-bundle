<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title|default('AsyncAPI') }}</title>
</head>
<body>
    <asyncapi-component
        schemaUrl="{{ schema_url }}"
        schemaFetchOptions='{"method":"GET"}'
        {% if ui_config %}config="{{ ui_config|json_encode|e('html_attr') }}"{% endif %}
        cssImportPath="{{ css_import_path }}">
    </asyncapi-component>

    {# Declarative custom element: no inline JavaScript, so it works under a strict CSP. #}
    {# Add @webcomponents/webcomponentsjs before this script only to support legacy browsers. #}
    <script src="https://unpkg.com/@asyncapi/web-component@3.1.3/lib/asyncapi-web-component.js" defer></script>
</body>
</html>
